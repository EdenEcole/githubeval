pipeline {
    agent any
    stages {
        stage('Checkout SCM') {
            steps {
                cleanWs()
                git branch: 'main', credentialsId: 'EdenEcole', url: 'https://github.com/EdenEcole/githubeval.git'
            }
        }
        stage('Install Docker') {
            steps {
                sh 'sudo apt install docker.io -y || true'
                sh 'sudo chmod 666 /var/run/docker.sock'
                sh 'sudo systemctl start docker.service || true'
            }
        }
        stage('Build image nginx') {
            steps {
                sh 'docker build -t my-nginx .'
                sh 'docker image ls'
            }
        }
        stage('Clean') {
            steps {
                sh 'docker stop myapp || true'
                sh 'docker rm myapp || true'
            }
        }
        stage('Deploy myapp') {
            steps {
                sh 'docker run -d --name myapp --hostname myapp -p 80:80 my-nginx'
                sh 'docker ps'
            }
        }
        stage('Copy monsite') {
            steps {
                sh 'docker cp ./monsite/. myapp:/var/www/html/'
                sh 'docker exec myapp nginx -s reload || true'
            }
        }
    }
}
