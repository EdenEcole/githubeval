pipeline {
    agent any

    stages {
        stage('checkout-scm') {
            steps {
                cleanWs()
                git branch: 'main', credentialsId: 'EdenEcole', url: 'https://github.com/EdenEcole/githubeval.git'
            }
        }

        stage('Build image nginx') {
            steps {
                sh 'docker build -f dockerfile.txt -t my-nginx .'
                sh 'docker images ls'
            }
        }
    }
